# Copie para ".env" (ou configure na plataforma de deploy).
# URL da API. No Vite, variáveis expostas ao front PRECISAM começar com VITE_.
VITE_API_URL="http://localhost:3000"

# Número do WhatsApp da loja usado no botão "Falar com a loja".
# Formato internacional, só dígitos: 55 (Brasil) + DDD + número.
# Opcional — se não definir, usa o padrão em src/config/loja.ts.
VITE_WHATSAPP_NUMERO="5515998512564"
